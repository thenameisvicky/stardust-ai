{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "lldb",
      "request": "launch",
      "name": "Run Server",
      "cargo": {
        "args": [
          "run",
          "--bin",
          "server"
        ],
        "filter": {
          "name": "server",
          "kind": "bin"
        }
      },
      "cwd": "${workspaceFolder}"
    }
  ]
}